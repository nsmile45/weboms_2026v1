DB_POOL_MIN=2
DB_POOL_MAX=10

# Oracle Instant Client 경로 (구버전 Oracle DB용)
# 다운로드: https://www.oracle.com/database/technologies/instant-client/downloads.html
# 압축 해제 후 backend/instantclient/ 폴더에 넣거나 아래 경로 수정
ORACLE_CLIENT_PATH=C:\WEBOMS\backend\instantclient
